# NemoClaw Multi-Tenant Control Plane — Development Environment
#
# Copy this file to .env and fill in the values.
# DO NOT commit .env with real credentials.

# PostgreSQL connection (matches scripts/dev-control-plane.sh defaults)
NEMOCLAW_CP_DATABASE_URL=postgres://nemoclaw:dev-password-not-for-production@localhost:5432/nemoclaw_control_plane

# Control plane admin API key (for platform operator endpoints)
NEMOCLAW_CP_ADMIN_KEY=dev-admin-key

# Billing provider configuration (provider-agnostic: stripe | paddle | lemonsqueezy | mock)
NEMOCLAW_CP_BILLING_PROVIDER=mock
NEMOCLAW_CP_BILLING_API_KEY=
NEMOCLAW_CP_BILLING_WEBHOOK_SECRET=

# Platform-provided AI keys (for tenants using credentialMode=platform or hybrid)
# Leave empty if all tenants use BYOK
NEMOCLAW_CP_PLATFORM_NVIDIA_KEY=
NEMOCLAW_CP_PLATFORM_OPENAI_KEY=

# Tenant sandbox image (for OpenShell sandbox creation)
NEMOCLAW_CP_SANDBOX_IMAGE=ghcr.io/nvidia/openshell-community/sandboxes/openclaw:latest

# Port allocation range for tenant sandboxes
NEMOCLAW_CP_PORT_RANGE_START=19000
NEMOCLAW_CP_PORT_RANGE_END=29000

# Warm pool configuration
NEMOCLAW_CP_WARM_POOL_MIN_SIZE=2
NEMOCLAW_CP_WARM_POOL_MAX_SIZE=10

# Usage collection interval (seconds)
NEMOCLAW_CP_USAGE_COLLECTION_INTERVAL=300
