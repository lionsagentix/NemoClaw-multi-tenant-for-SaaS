{
  "name": "nemoclaw-control-plane",
  "version": "0.1.0",
  "description": "NemoClaw Multi-Tenant Control Plane — manages tenant lifecycle, billing, and sandbox orchestration",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run format:check && tsc --noEmit",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "pg": "^8.13.0",
    "express": "^4.21.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/pg": "^8.11.6",
    "@types/express": "^4.17.21",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
